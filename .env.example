# App
APP_NAME="API Security Engine"
VERSION="1.0.0"
DEBUG=True
API_KEY="dev-api-key-change-in-production"

# Database
DATABASE_URL="sqlite+aiosqlite:///./api_security.db"
# Example PostgreSQL URL:
# DATABASE_URL="postgresql+asyncpg://postgres:postgres@localhost:5432/api_security"

# Redis (optional)
# REDIS_URL="redis://localhost:6379/0"

# Kafka (optional)
# KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
# KAFKA_ENABLED=False

# Tests Library
# TESTS_LIBRARY_PATH="./tests-library"

# mitmproxy
MITMPROXY_PORT=8080
MITMPROXY_HOST="127.0.0.1"

# WAF / Coraza (optional)
# CORAZA_URL="http://localhost:8080"

# Security / JWT
JWT_SECRET="change-me-in-production-32-char-minimum"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440

# Third-Party Integrations (Optional)
# GITHUB_CLIENT_ID=""
# GITHUB_CLIENT_SECRET=""
# OAUTH_REDIRECT_BASE_URL="http://localhost:8000"
# DATADOG_API_KEY=""
# STRIPE_SECRET_KEY=""
