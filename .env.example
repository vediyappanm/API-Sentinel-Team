# App
APP_NAME="API Security Engine"
VERSION="1.0.0"
DEBUG=False
API_KEY="generate-a-long-secure-key-here"
JWT_SECRET="generate-a-64-char-secret-here"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=1440
ENCRYPTION_KEY="generate-a-44-plus-char-fernet-key-here"
UNIFIED_PIPELINE_MODE="shadow"

# Database
DATABASE_URL="postgresql+asyncpg://app_user:secure_password_here@localhost:5432/api_security"

# Redis / Kafka (optional)
# REDIS_URL="redis://localhost:6379/0"
# KAFKA_BOOTSTRAP_SERVERS="localhost:9092"
# KAFKA_ENABLED=False

# Security / CORS
CORS_ORIGINS_OVERRIDE="https://app.example.com"
TENANT_RLS_ENABLED=True

# Startup / deploy safety
STARTUP_BOOTSTRAP_SCHEMA=False
STARTUP_ENABLE_DEMO_BOOTSTRAP=False
STARTUP_REFRESH_TEMPLATE_LIBRARY=True
STARTUP_ENSURE_DEFAULT_PLAYBOOKS=False
STARTUP_ENABLE_ANALYTICS_PROCESSOR=False
STARTUP_ENABLE_ARCHIVER=False
STARTUP_ENABLE_TEST_SCHEDULER=True
STARTUP_ENABLE_INGESTION_QUEUE=True
STARTUP_ENABLE_WARM_EXPORTER=True
STARTUP_ENABLE_ENDPOINT_LIFECYCLE=True
STARTUP_ENABLE_RECON_SCHEDULER=True
STARTUP_ENABLE_STREAM_PIPELINE=True

# Tests Library
TESTS_LIBRARY_PATH="./tests-library"

# Optional integrations
# CORAZA_URL="http://localhost:8080"
# DATADOG_API_KEY=""
# STRIPE_SECRET_KEY=""
